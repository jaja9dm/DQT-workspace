# ── KIS API (한국투자증권) ─────────────────────────
KIS_APP_KEY=발급받은_앱키
KIS_APP_SECRET=발급받은_앱시크릿
KIS_ACCOUNT_NO=계좌번호-상품코드   # ex) 12345678-01
KIS_MODE=paper                     # paper(모의) | live(실전)

# ── Claude / Anthropic ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── 알림 ─────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
KAKAO_ACCESS_TOKEN=카카오_액세스_토큰

# ── 외부 API ──────────────────────────────────────
FRED_API_KEY=FRED_API_키            # 미국 경제지표 (https://fred.stlouisfed.org)

# ── DB 경로 (기본값: db/dqt.db) ──────────────────
