# ── KIS API (한국투자증권) ─────────────────────────
KIS_APP_KEY=발급받은_앱키
KIS_APP_SECRET=발급받은_앱시크릿
KIS_ACCOUNT_NO=계좌번호-상품코드   # ex) 12345678-01
KIS_MODE=paper                     # paper(모의) | live(실전)

# ── Claude / Anthropic ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── 알림 (텔레그램) ──────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...    # BotFather에서 발급
TELEGRAM_CHAT_ID=-100123456789            # 채널/그룹 ID (음수이면 채널)

# ── 외부 API ──────────────────────────────────────
FRED_API_KEY=FRED_API_키            # 미국 경제지표 (https://fred.stlouisfed.org)

# ── DB 경로 (기본값: db/dqt.db) ──────────────────
# DB_PATH=/custom/path/dqt.db

# ── 리스크 파라미터 (기본값 변경 시만 설정) ──────────
# RISK_MAX_SINGLE_TRADE_PCT=10
# STOP_LOSS_DEFAULT_PCT=5.0
# STOP_LOSS_LEVEL2_PCT=3.0
# STOP_LOSS_LEVEL4_PCT=1.0
# TAKE_PROFIT_1_PCT=5.0
# TAKE_PROFIT_2_PCT=10.0
# POSITION_MAX_HOLD_DAYS=5

# ── 트레일링 스톱 파라미터 (기본값 변경 시만 설정) ──
# TRAILING_INITIAL_STOP_PCT=10.0   # 초기 손절선: 매수가 대비 -10%
# TRAILING_TRIGGER_PCT=10.0        # 손절선 올리기 시작: 매수가 대비 +10% 수익 시
# TRAILING_FLOOR_PCT=5.0           # 트레일링 간격: 현재가 대비 -5%
# LADDER_TRIGGER_PCT=20.0          # 사다리 매수 발동: 매수가 대비 -20% 하락 시
# LADDER_QTY_RATIO=1.0             # 사다리 매수 수량: 기존 보유량의 1배
